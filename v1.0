loadstring(game:HttpGet("https://raw.githubusercontent.com/dangdizi/DiziHub/refs/heads/main/UI-D2.0.lua"))()
local DiziGui = Dizi:new()

DiziGui:setTitle("Garden Horizons - Dizi Hub")


local InfoAction = DiziGui:createAction(true)
local InfoTab = DiziGui:createTab("rbxassetid://133458018032042", "Teleport")
InfoTab:setAction(InfoAction)

InfoAction:createLabel("Giới thiệu phiên bản", Color3.fromRGB(45, 120, 217))
InfoAction:createHr()
InfoAction:createText("Version: V1.0", Color3.fromRGB(255,255,255))
InfoAction:createText("Author: Đăng Dizi", Color3.fromRGB(255,255,255))
InfoAction:createText("Chức năng: tự thu hoạch, bán, mua hạt giống", Color3.fromRGB(255,255,255))
InfoAction:createHr()
InfoAction:createText("Kịch bản lỗi vui lòng báo ngay cho tôi: dizi.fishing@gmail.com", Color3.fromRGB(229, 38, 38))



local AutoFarmAction = DiziGui:createAction()
local AutoFarmTab = DiziGui:createTab("rbxassetid://133458018032042", "Tự động farm")
AutoFarmTab:setAction(AutoFarmAction)

AutoFarmAction:createLabel("Tự động thu hoạch & bán", Color3.fromRGB(192, 237, 32))
AutoFarmAction:createHr()
AutoFarmAction:createText("toàn bộ nông sản sẽ được bán, hãy khóa các nông sản quý giá của bạn lại!")


local flagFarm = false
local runningFarm = false
AutoFarmAction:createToggleSwitch("Tự động thu hoạch & bán", function(status)
    flagFarm = status

    if status and not runningFarm then
        runningFarm = true
        task.spawn(function()
            while flagFarm do
                local PlantFolder = workspace.ClientPlants
                for _, plant in pairs(PlantFolder:GetChildren()) do
                    local count = 0
                    local uuid = plant:GetAttribute("Uuid")
                    for _, obj in pairs(plant:GetChildren()) do
                        if string.match(obj.Name, "Fruit%d+$") then
                            count += 1
                        end
                    end
                end

                if count > 1 then
                    for i = 1, count do
                        local args = {
                            [1] = {
                                [1] = {
                                    ["GrowthAnchorIndex"] = i,
                                    ["Uuid"] = uuid
                                }
                            }
                        }

                        game:GetService("ReplicatedStorage").RemoteEvents.HarvestFruit:FireServer(unpack(args))
                    end
                else
                    local args = {
                            [1] = {
                                [1] = {
                                    ["Uuid"] = uuid
                                }
                            }
                        }

                    game:GetService("ReplicatedStorage").RemoteEvents.HarvestFruit:FireServer(unpack(args))
                end
                task.wait(1)
                local sellArgs = {
                    [1] = "SellAll"
                }
                game:GetService("ReplicatedStorage").RemoteEvents.SellItems:InvokeServer(unpack(sellArgs))
                task.wait(1)
            end
            runningFarm = false
        end)
    end
end)
