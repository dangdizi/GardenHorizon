local AutoFarmAction = DiziGui:createAction()
local AutoFarmTab = DiziGui:createTab("rbxassetid://133458018032042", "Tự động farm")
AutoFarmTab:setAction(AutoFarmAction)

AutoFarmAction:createLabel("Tự động thu hoạch & bán", Color3.fromRGB(192, 237, 32))
AutoFarmAction:createHr()
AutoFarmAction:createText("toàn bộ nông sản sẽ được bán, hãy khóa các nông sản quý giá của bạn lại!")

local flag = false
local running = false

AutoFarmAction:createToggleSwitch("Auto Farm", function(status)
    flag = status

    if status and not running then
        running = true
        task.spawn(function()
            while flag do
                local folder = workspace:WaitForChild("ClientPlants")

                for _, plant in pairs(folder:GetChildren()) do
                    task.spawn(function()
                        local count = 0
                        local uuid = plant:GetAttribute("Uuid")
                        -- Script generated by SimpleSpy - credits to exx#9394
                        for _, obj in pairs(plant:GetChildren()) do
                            if string.match(obj.Name, "^Fruit%d+$") then
                                count += 1
                            end
                        end
                        if count > 0 then
                            for i = 1, count do
                            local args = {
                                [1] = {
                                    [1] = {
                                        ["GrowthAnchorIndex"] = i,
                                        ["Uuid"] = uuid
                                    }
                                }
                            }

                            game:GetService("ReplicatedStorage").RemoteEvents.HarvestFruit:FireServer(unpack(args))
                            task.wait(0.5)
                            end
                        else
                        local args = {
                                [1] = {
                                    [1] = {
                                        ["Uuid"] = uuid
                                    }
                                }
                            }

                            game:GetService("ReplicatedStorage").RemoteEvents.HarvestFruit:FireServer(unpack(args))
                        end

                    end)
                    task.wait(1)
                end

                -- Script generated by SimpleSpy - credits to exx#9394

                --local args = {
                    --[1] = "SellAll"
               -- }

               -- game:GetService("ReplicatedStorage").RemoteEvents.SellItems:InvokeServer(unpack(args))

                task.wait(15)
            end
            running = false
        end)
    end
end)




AutoFarmAction:createLabel("Tự động mua hạt giống", Color3.fromRGB(57, 193, 234))
AutoFarmAction:createText("Mua tất cả các hạt giống trong cửa hàng", Color3.fromRGB(255, 255, 255))

local flasSeed = false
local runningSeed = false

AutoFarmAction:createToggleSwitch("Auto Buy Seed", function(status)
    local RS = game:GetService("ReplicatedStorage")
    local Shop = "SeedShop"
    local  LastSeed

    while task.wait(0.5) do
        local Data = RS.RemoteEvents.GetShopData:InvokeServer(Shop)
        if Data.Seed ~= LastSeed then
            LastSeed = Data.Seed

            for itemName, info in pairs(Data.Items) do
                task.spawn(function()
                    
                end)
                for i = 1, info.Amount do
                    task.spawn(function()
                        RS.RemoteEvents.PurchaseShopItem:InvokeServer(Shop, itemName)
                    end)
                end
            end
        end
    end
end)
